# Environment Variables
# Copy this file to .env.local and fill in your values

# GitHub Personal Access Token
# Required for the Projects section (fetches your pinned repos via GitHub GraphQL API)
# Create one at: https://github.com/settings/tokens
# Scopes needed: read:user (public_repo scope is sufficient — read-only)
GITHUB_TOKEN=your_github_personal_access_token_here

# Site Identity
# These variables can be set in Vercel dashboard under Environment Variables
EMAIL=your-email@example.com
WEBSITE_URL=https://yourwebsite.com
SITE_NAME=Your Name - Your Title
SITE_DESCRIPTION=Your professional description here.
ABOUT_TEXT=Your about text describing your background and interests.

# Site Keywords (JSON array of strings)
SITE_KEYWORDS=["keyword1","keyword2","keyword3"]

# Work Experience (JSON array of objects)
# Each object should have: company, title, start, end, link, id
WORK_EXPERIENCE=[{"company":"Company Name","title":"Job Title","start":"YYYY MMM","end":"present","link":"https://company.com/","id":"work1"}]

# Social Links (JSON array of objects)
# Each object should have: label, link
SOCIAL_LINKS=[{"label":"Github","link":"https://github.com/yourusername"},{"label":"LinkedIn","link":"https://www.linkedin.com/in/yourusername"},{"label":"Twitter","link":"https://twitter.com/yourusername"}]

# External Integrations
GITHUB_USERNAME=yourgithubusername
MEDIUM_USERNAME=yourmediumusername
